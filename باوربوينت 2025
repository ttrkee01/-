      flex: 1;
      height: 18px;
      background: rgba(255,255,255,0.07);
      border-radius: 9px;
      overflow: hidden;
      position: relative;
    }

    .gap-fill {
      height: 100%;
      border-radius: 9px;
      transition: width 1.4s cubic-bezier(0.34, 1.2, 0.64, 1);
      position: relative;
    }

