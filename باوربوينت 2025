<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>مدينة الملك سعود الطبية - توظيف خدمات الطوارئ الطبية</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;900&family=Amiri:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --blue-dark:   #071630;
      --blue-mid:    #0D2247;
      --blue:        #1B3A6E;
      --blue-light:  #2A5298;
      --blue-bright: #3A6FD8;
      --gold:        #C9A84C;
      --gold-light:  #E8C86A;
      --gold-pale:   #F5E6B8;
      --gold-dark:   #9A7230;
      --white:       #FFFFFF;
      --off-white:   #F0EBE0;
      --text-dim:    rgba(255,255,255,0.65);
      --sidebar-w:   260px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Cairo', sans-serif;
      background: var(--blue-dark);
      color: var(--white);
      display: flex;
      height: 100vh;
      overflow: hidden;
      direction: rtl;
    }

    /* ───── SIDEBAR ───── */
    #sidebar {
      width: var(--sidebar-w);
      height: 100vh;
      background: linear-gradient(180deg, #061128 0%, #0D2247 60%, #0a1a38 100%);
      border-left: 1px solid rgba(201,168,76,0.25);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      position: relative;
      z-index: 10;
    }

    .sidebar-brand {
      padding: 28px 20px 20px;
      border-bottom: 1px solid rgba(201,168,76,0.2);
      text-align: center;
    }

    .brand-emblem {
      width: 64px;
      height: 64px;
      margin: 0 auto 12px;
      background: radial-gradient(circle, var(--gold) 0%, var(--gold-dark) 100%);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      font-weight: 900;
      color: var(--blue-dark);
      font-family: 'Amiri', serif;
      box-shadow: 0 0 24px rgba(201,168,76,0.4);
      letter-spacing: -1px;
    }

    .brand-name {
      font-size: 11px;
      font-weight: 600;
      color: var(--gold-light);
      line-height: 1.5;
      letter-spacing: 0.5px;
    }

    .brand-sub {
      font-size: 9.5px;
      color: var(--text-dim);
      margin-top: 3px;
    }

    .sidebar-nav {
      flex: 1;
      overflow-y: auto;
      padding: 16px 12px;
      scrollbar-width: thin;
      scrollbar-color: var(--gold-dark) transparent;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 8px;
      cursor: pointer;
      margin-bottom: 4px;
      transition: all 0.25s ease;
      position: relative;
    }

    .nav-item:hover { background: rgba(42,82,152,0.4); }

    .nav-item.active {
      background: linear-gradient(135deg, rgba(201,168,76,0.2), rgba(42,82,152,0.3));
      border: 1px solid rgba(201,168,76,0.35);
    }

    .nav-item.active::before {
      content: '';
      position: absolute;
      right: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 60%;
      background: var(--gold);
      border-radius: 0 3px 3px 0;
    }

    .nav-num {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: rgba(255,255,255,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 11px;
      font-weight: 700;
      flex-shrink: 0;
      transition: all 0.25s;
    }

    .nav-item.active .nav-num {
      background: var(--gold);
      color: var(--blue-dark);
    }

    .nav-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-dim);
      line-height: 1.3;
      transition: color 0.25s;
    }

    .nav-item.active .nav-label { color: var(--white); }

    .sidebar-footer {
      padding: 16px 20px;
      border-top: 1px solid rgba(201,168,76,0.15);
      text-align: center;
    }

    .progress-bar-wrap {
      height: 4px;
      background: rgba(255,255,255,0.1);
      border-radius: 2px;
      overflow: hidden;
      margin-bottom: 8px;
    }

    #progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--gold-dark), var(--gold-light));
      border-radius: 2px;
      transition: width 0.4s ease;
    }

    .slide-counter {
      font-size: 11px;
      color: var(--text-dim);
    }

    .slide-counter span { color: var(--gold-light); font-weight: 700; }

    /* ───── MAIN AREA ───── */
    #main {
      flex: 1;
      height: 100vh;
      position: relative;
      overflow: hidden;
    }

    /* ───── SLIDES ───── */
    .slide {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      opacity: 0;
      pointer-events: none;
      transform: translateX(40px);
      transition: opacity 0.5s ease, transform 0.5s ease;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--gold-dark) transparent;
    }

    .slide.active {
      opacity: 1;
      pointer-events: all;
      transform: translateX(0);
    }

    .slide.exit {
      opacity: 0;
      transform: translateX(-40px);
    }

    /* ───── NAV BUTTONS ───── */
    .nav-btns {
      position: fixed;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 14px;
      z-index: 100;
    }

    .nav-btn {
      padding: 10px 28px;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      font-family: 'Cairo', sans-serif;
      font-size: 14px;
      font-weight: 700;
      transition: all 0.25s;
      letter-spacing: 0.3px;
    }

    .btn-prev {
      background: rgba(255,255,255,0.08);
      color: var(--white);
      border: 1px solid rgba(255,255,255,0.2);
    }

    .btn-prev:hover { background: rgba(255,255,255,0.15); }

    .btn-next {
      background: linear-gradient(135deg, var(--gold-dark), var(--gold));
      color: var(--blue-dark);
    }

    .btn-next:hover {
      background: linear-gradient(135deg, var(--gold), var(--gold-light));
      box-shadow: 0 4px 20px rgba(201,168,76,0.45);
      transform: translateY(-1px);
    }

    .btn-prev:disabled, .btn-next:disabled {
      opacity: 0.3;
      cursor: default;
      transform: none;
    }

    /* ───── SHARED SLIDE ELEMENTS ───── */
    .slide-header {
      padding: 40px 60px 0;
      position: relative;
    }

    .slide-tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 2px;
      color: var(--gold);
      text-transform: uppercase;
      margin-bottom: 10px;
      padding: 4px 14px;
      background: rgba(201,168,76,0.12);
      border: 1px solid rgba(201,168,76,0.3);
      border-radius: 20px;
    }

    .slide-title {
      font-size: 34px;
      font-weight: 900;
      line-height: 1.25;
      color: var(--white);
    }

    .slide-title .gold { color: var(--gold-light); }

    .slide-divider {
      width: 80px;
      height: 3px;
      background: linear-gradient(90deg, var(--gold), transparent);
      margin: 16px 0;
      border-radius: 2px;
    }

    .slide-body {
      flex: 1;
      padding: 20px 60px 80px;
    }

    /* ───── STAT CARDS ───── */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 18px;
      margin-top: 24px;
    }

    .stat-card {
      background: linear-gradient(135deg, rgba(42,82,152,0.3), rgba(27,58,110,0.5));
      border: 1px solid rgba(201,168,76,0.2);
      border-radius: 14px;
      padding: 24px 20px;
      text-align: center;
      position: relative;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .stat-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 28px rgba(0,0,0,0.3);
      border-color: rgba(201,168,76,0.4);
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 60px;
      height: 60px;
      background: radial-gradient(circle, rgba(201,168,76,0.12), transparent);
      border-radius: 0 14px 0 100%;
    }

    .stat-value {
      font-size: 38px;
      font-weight: 900;
      color: var(--gold-light);
      line-height: 1;
      font-family: 'Amiri', serif;
    }

    .stat-unit {
      font-size: 16px;
      color: var(--gold);
      font-weight: 700;
    }

    .stat-label {
      font-size: 12.5px;
      color: var(--text-dim);
      margin-top: 8px;
      line-height: 1.4;
    }

    /* ───── INFO ROWS ───── */
    .info-row {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 14px 18px;
      background: rgba(255,255,255,0.04);
      border-radius: 10px;
      border-right: 3px solid var(--gold);
      margin-bottom: 10px;
      transition: background 0.2s;
    }

    .info-row:hover { background: rgba(255,255,255,0.07); }

    .info-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
      margin-top: 6px;
    }

    .info-text {
      font-size: 14.5px;
      color: var(--off-white);
      line-height: 1.7;
    }

    .info-text strong { color: var(--gold-light); }

    /* ───── TWO COLUMNS ───── */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 24px;
    }

    .col-box {
      background: linear-gradient(160deg, rgba(27,58,110,0.4), rgba(13,34,71,0.6));
      border: 1px solid rgba(201,168,76,0.18);
      border-radius: 14px;
      padding: 24px;
    }

    .col-box-title {
      font-size: 15px;
      font-weight: 800;
      color: var(--gold-light);
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 1px solid rgba(201,168,76,0.2);
    }

    /* ───── SLIDE 1: COVER ───── */
    #slide-1 {
      background:
        radial-gradient(ellipse at 30% 20%, rgba(42,82,152,0.5) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 80%, rgba(201,168,76,0.12) 0%, transparent 50%),
        linear-gradient(160deg, #071630 0%, #0D2247 50%, #071630 100%);
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .cover-geo {
      position: absolute;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
    }

    .geo-ring {
      position: absolute;
      border-radius: 50%;
      border: 1px solid rgba(201,168,76,0.15);
    }

    .geo-ring:nth-child(1) { width: 500px; height: 500px; top: -150px; left: -150px; }
    .geo-ring:nth-child(2) { width: 700px; height: 700px; top: -250px; left: -250px; border-color: rgba(201,168,76,0.07); }
    .geo-ring:nth-child(3) { width: 400px; height: 400px; bottom: -100px; right: -100px; border-color: rgba(42,82,152,0.3); }

    .cover-inner { position: relative; z-index: 2; max-width: 800px; padding: 40px; }

    .cover-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 20px;
      background: rgba(201,168,76,0.15);
      border: 1px solid rgba(201,168,76,0.4);
      border-radius: 30px;
      font-size: 12px;
      font-weight: 700;
      color: var(--gold-light);
      letter-spacing: 1.5px;
      margin-bottom: 28px;
    }

    .cover-badge-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--gold);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%,100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.5); opacity: 0.6; }
    }

    .cover-title {
      font-family: 'Amiri', serif;
      font-size: 52px;
      font-weight: 700;
      line-height: 1.3;
      color: var(--white);
      margin-bottom: 10px;
    }

    .cover-title .gold { color: var(--gold); }

    .cover-subtitle {
      font-size: 22px;
      font-weight: 600;
      color: var(--gold-light);
      margin-bottom: 8px;
    }

    .cover-desc {
      font-size: 15px;
      color: var(--text-dim);
      max-width: 560px;
      margin: 0 auto 36px;
      line-height: 1.8;
    }

    .cover-meta {
      display: flex;
      justify-content: center;
      gap: 40px;
      flex-wrap: wrap;
    }

    .meta-item { text-align: center; }

    .meta-val {
      font-size: 24px;
      font-weight: 900;
      color: var(--gold-light);
      font-family: 'Amiri', serif;
    }

    .meta-lbl {
      font-size: 11px;
      color: var(--text-dim);
      margin-top: 2px;
    }

    .cover-line {
      width: 120px;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
      margin: 28px auto;
    }

    /* ───── SLIDE 5: CHART ───── */
    .chart-area {
      display: flex;
      align-items: flex-end;
      justify-content: center;
      gap: 50px;
      height: 300px;
      margin: 30px 0 16px;
      position: relative;
    }

    .chart-area::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: rgba(255,255,255,0.15);
    }

    .chart-gridlines {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      pointer-events: none;
    }

    .grid-line {
      width: 100%;
      height: 1px;
      background: rgba(255,255,255,0.06);
    }

    .bar-group {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      position: relative;
      z-index: 2;
    }

    .bar-value-label {
      font-size: 20px;
      font-weight: 900;
      font-family: 'Amiri', serif;
      color: var(--gold-light);
    }

    .bar-wrap {
      width: 100px;
      background: rgba(255,255,255,0.05);
      border-radius: 8px 8px 0 0;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
      position: relative;
    }

    .bar {
      width: 100%;
      border-radius: 8px 8px 0 0;
      position: relative;
      transform-origin: bottom;
      transition: height 1.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .bar-2023 { background: linear-gradient(180deg, #3A6FD8, #2A5298); }
    .bar-2025 { background: linear-gradient(180deg, var(--gold-light), var(--gold-dark)); }

    .bar-year {
      font-size: 16px;
      font-weight: 800;
      color: var(--text-dim);
    }

    .growth-badge {
      position: absolute;
      top: -50px;
      right: 50%;
      transform: translateX(50%);
      background: linear-gradient(135deg, var(--gold), var(--gold-dark));
      color: var(--blue-dark);
      font-size: 14px;
      font-weight: 900;
      padding: 8px 16px;
      border-radius: 20px;
      white-space: nowrap;
      box-shadow: 0 4px 16px rgba(201,168,76,0.4);
      animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
      0%,100% { transform: translateX(50%) translateY(0); }
      50% { transform: translateX(50%) translateY(-6px); }
    }

    .growth-arrow {
      position: absolute;
      top: 50%;
      right: 50%;
      transform: translate(50%, -50%);
      display: flex;
      align-items: center;
    }

    .chart-legend {
      display: flex;
      justify-content: center;
      gap: 32px;
      margin-top: 20px;
    }

    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--text-dim);
    }

    .legend-dot {
      width: 12px;
      height: 12px;
      border-radius: 3px;
    }

    /* ───── TIMELINE ───── */
    .timeline {
      position: relative;
      margin-top: 24px;
    }

    .timeline::before {
      content: '';
      position: absolute;
      right: 20px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(180deg, var(--gold), rgba(201,168,76,0.2));
    }

    .timeline-item {
      display: flex;
      gap: 24px;
      margin-bottom: 20px;
      padding-right: 52px;
      position: relative;
    }

    .timeline-dot {
      position: absolute;
      right: 11px;
      top: 10px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--gold), var(--gold-dark));
      border: 3px solid var(--blue-dark);
      box-shadow: 0 0 10px rgba(201,168,76,0.4);
    }

    .timeline-content {
      flex: 1;
      background: rgba(42,82,152,0.2);
      border: 1px solid rgba(201,168,76,0.15);
      border-radius: 10px;
      padding: 14px 18px;
    }

    .timeline-phase {
      font-size: 12px;
      color: var(--gold);
      font-weight: 700;
      letter-spacing: 1px;
    }

    .timeline-title {
      font-size: 15px;
      font-weight: 800;
      color: var(--white);
      margin: 4px 0;
    }

    .timeline-desc {
      font-size: 13px;
      color: var(--text-dim);
      line-height: 1.5;
    }

    /* ───── POSITION TABLE ───── */
    .pos-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    .pos-table th {
      background: rgba(201,168,76,0.15);
      color: var(--gold-light);
      font-size: 13px;
      font-weight: 700;
      padding: 12px 16px;
      border-bottom: 1px solid rgba(201,168,76,0.3);
      text-align: right;
    }

    .pos-table td {
      padding: 11px 16px;
      font-size: 13.5px;
      color: var(--off-white);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .pos-table tr:hover td { background: rgba(255,255,255,0.04); }

    .pos-table tr:last-child td { border-bottom: none; }

    .badge-level {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 12px;
      font-size: 11.5px;
      font-weight: 700;
    }

    .badge-high {
      background: rgba(220,60,60,0.2);
      color: #ff8080;
      border: 1px solid rgba(220,60,60,0.3);
    }

    .badge-med {
      background: rgba(201,168,76,0.2);
      color: var(--gold-light);
      border: 1px solid rgba(201,168,76,0.3);
    }

    /* ───── LETTER SLIDE ───── */
    .letter-wrap {
      background: rgba(240,235,224,0.04);
      border: 1px solid rgba(201,168,76,0.2);
      border-radius: 14px;
      padding: 32px 36px;
      margin-top: 20px;
      position: relative;
    }

    .letter-wrap::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 4px;
      height: 100%;
      background: linear-gradient(180deg, var(--gold), var(--gold-dark));
      border-radius: 4px 0 0 4px;
    }

    .letter-heading {
      text-align: center;
      margin-bottom: 20px;
      padding-bottom: 16px;
      border-bottom: 1px solid rgba(201,168,76,0.2);
    }

    .letter-title-ar {
      font-family: 'Amiri', serif;
      font-size: 20px;
      font-weight: 700;
      color: var(--gold-light);
    }

    .letter-ref {
      font-size: 12px;
      color: var(--text-dim);
      margin-top: 4px;
    }

    .letter-body p {
      font-size: 14px;
      line-height: 2;
      color: var(--off-white);
      margin-bottom: 14px;
      text-align: justify;
    }

    .letter-body p.basmala {
      text-align: center;
      font-family: 'Amiri', serif;
      font-size: 20px;
      color: var(--gold-light);
      margin-bottom: 20px;
    }

    .letter-body strong { color: var(--gold-light); }

    /* ───── QUAL BOXES ───── */
    .qual-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-top: 20px;
    }

    .qual-card {
      background: rgba(27,58,110,0.35);
      border: 1px solid rgba(201,168,76,0.18);
      border-radius: 12px;
      padding: 20px;
    }

    .qual-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: rgba(201,168,76,0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 12px;
    }

    .qual-icon svg { width: 22px; height: 22px; fill: var(--gold); }

    .qual-title {
      font-size: 14px;
      font-weight: 800;
      color: var(--white);
      margin-bottom: 8px;
    }

    .qual-list {
      list-style: none;
    }

    .qual-list li {
      font-size: 13px;
      color: var(--text-dim);
      padding: 4px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .qual-list li::before {
      content: '';
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }

    /* ───── CONCLUSION ───── */
    .conclusion-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 16px;
      margin-top: 20px;
    }

    .concl-card {
