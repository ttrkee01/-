  <button class="nav-btn btn-next" onclick="nextSlide()">التالي &lsaquo;</button>
  <button class="nav-btn btn-prev" onclick="prevSlide()" disabled>&#8250; السابق</button>
</div>

<script>
  let current = 1;
  const total  = 10;
  let chartAnimated = false;
  let gapAnimated   = false;

  function goTo(n) {
    if (n < 1 || n > total) return;

    const prev = document.getElementById('slide-' + current);
    prev.classList.remove('active');
    prev.classList.add('exit');
    setTimeout(() => prev.classList.remove('exit'), 500);

    current = n;

    const next = document.getElementById('slide-' + current);
    next.classList.add('active');

    // Update sidebar
    document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
    document.querySelector('.nav-item[data-slide="' + current + '"]').classList.add('active');

    // Progress
    document.getElementById('progress-bar').style.width = ((current / total) * 100) + '%';
    document.getElementById('cur-num').textContent = current;

    // Buttons
    document.querySelector('.btn-prev').disabled = (current === 1);
    document.querySelector('.btn-next').disabled = (current === total);
    document.querySelector('.btn-next').textContent = current === total ? 'النهاية' : 'التالي ‹';

    // Trigger animations
    if (current === 5 && !chartAnimated) { animateChart(); chartAnimated = true; }
    if (current === 6 && !gapAnimated)   { animateGaps();  gapAnimated = true; }
    if (current === 5) { chartAnimated = false; setTimeout(() => { animateChart(); chartAnimated = true; }, 100); }
    if (current === 6) { gapAnimated = false; setTimeout(() => { animateGaps(); gapAnimated = true; }, 100); }
  }

  function nextSlide() { goTo(current + 1); }
  function prevSlide() { goTo(current - 1); }

  // Chart animation
  function animateChart() {
    const bar2023 = document.getElementById('bar-2023');
    const bar2025 = document.getElementById('bar-2025');
    const maxH = 280;
    const h2023 = Math.round((637 / 933) * maxH);
    const h2025 = maxH;

    bar2023.style.height = '0px';
    bar2025.style.height = '0px';

    setTimeout(() => { bar2023.style.height = h2023 + 'px'; }, 300);
    setTimeout(() => { bar2025.style.height = h2025 + 'px'; }, 500);
  }

  // Gap bars animation
  function animateGaps() {
    document.querySelectorAll('.gap-fill').forEach(el => {
      el.style.width = '0%';
      const target = el.getAttribute('data-target');
      setTimeout(() => { el.style.width = target; }, 400);
    });
  }

  // Keyboard navigation
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowDown')  nextSlide();
    if (e.key === 'ArrowRight' || e.key === 'ArrowUp')    prevSlide();
  });
</script>
